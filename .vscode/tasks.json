{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build asm (current file)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "yasm -g dwarf2 -f elf64 \"${file}\" -o \"${fileBasenameNoExtension}.o\" && ld -g -o \"${fileBasenameNoExtension}\" \"${fileBasenameNoExtension}.o\""
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
